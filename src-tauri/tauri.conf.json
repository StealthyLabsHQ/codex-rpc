{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex RPC",
  "version": "0.3.9",
  "identifier": "eu.stealthylabs.codex-rich-presence",
  "mainBinaryName": "codex-rich-presence",
  "build": {
    "frontendDist": "../tauri-ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Codex RPC Settings",
        "width": 700,
        "height": 700,
        "minWidth": 660,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self'; style-src 'self'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["../assets/app.ico"]
  }
}
