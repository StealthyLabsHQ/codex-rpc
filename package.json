{
  "name": "codex-rich-presence",
  "version": "0.3.1",
  "description": "Codex RPC",
  "main": "dist/index.js",
  "bin": {
    "codex-rich-presence": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build && node scripts/export-tauri-exe.js",
    "pkg": "pkg . --targets node22-win-x64 --output bin/codex-rpc-daemon.exe",
    "dist": "node scripts/build-exe.js"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": ["assets/app.ico"]
  },
  "author": "StealthyLabs",
  "license": "MIT",
  "dependencies": {
    "@xhayper/discord-rpc": "^1.2.0",
    "dotenv": "^16.4.5",
    "pino": "^9.5.0",
    "pino-pretty": "^11.2.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^22.0.0",
    "@yao-pkg/pkg": "^6.1.1",
    "rcedit": "^4.0.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
