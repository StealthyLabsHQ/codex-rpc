# Optional. Overrides the bundled Codex Rich Presence Application ID.
# Only set this if you've forked the project and run your own Discord app.
# DISCORD_CLIENT_ID=

# Scan interval (ms). Default 5000. Do not go below 2000.
SCAN_INTERVAL_MS=5000

# Delay before falling back to IDLE after processes vanish (ms)
IDLE_GRACE_MS=10000

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Log file path (daily rotation). Empty = stdout only.
LOG_FILE=

# Override for tests: force a state without scanning processes
# FORCE_STATE=cli|app|both|idle
